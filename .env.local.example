# Supabase — copy this file to `.env.local` and fill in your project values.
# Found in your Supabase dashboard under Project Settings → API.

# Safe to expose to the browser (used by the anon/public client).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side ONLY — bypasses row-level security. Used by webhook handlers and
# other trusted server writes (src/utils/supabase/admin.ts). Never expose to the
# browser. Found under Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Anthropic (Claude) — server-side only, used for quote generation.
# Get a key at https://console.anthropic.com/ → API Keys.
ANTHROPIC_API_KEY=sk-ant-...

# Shared secret guarding POST /api/quote. Callers must send it as the
# `x-api-key` header. Generate one with: openssl rand -hex 32
# The endpoint fails closed (503) if this is unset.
QUOTE_API_SECRET=

# Quote Assistant (POST /api/inquiries) auto-quotes up to this subtotal in cents;
# above it, the inquiry is escalated to the operator. Default 75000 ($750).
QUOTE_AUTO_CAP_CENTS=75000

# Payments — which provider is active: stripe | square
PAYMENT_PROVIDER=stripe

# Stripe (server-side secrets)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Publishable key is safe for the browser (only needed for client-side Stripe.js).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# SignWell (e-signature) — server-side REST, no SDK.
# Which e-sign provider is active.
ESIGN_PROVIDER=signwell
# API key from SignWell → Settings → API.
SIGNWELL_API_KEY=
# The id of the webhook you created (SignWell → API → Webhooks). Used as the
# HMAC-SHA256 key to verify incoming webhook signatures.
SIGNWELL_WEBHOOK_ID=
# Default template to generate rental agreements from.
SIGNWELL_TEMPLATE_ID=
# When "true" (and template + sender are set), paying an order auto-sends its agreement.
SIGNWELL_AUTO_SEND=false
# Documents are test-mode (non-binding, non-billable) unless this is exactly "false".
SIGNWELL_TEST_MODE=true
# Company countersigner assigned to the template's "Document Sender" role.
SIGNWELL_SENDER_NAME=Bounce Party Rentals
SIGNWELL_SENDER_EMAIL=
# When "true", merges the operator's customer policies into the agreement.
# Requires the template to have text fields with api_ids `cancellation_policy`
# and `damage_policy`. Leave off until those fields exist, or sends will fail.
SIGNWELL_POLICY_FIELDS=false
