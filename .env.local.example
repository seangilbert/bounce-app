# Supabase — copy this file to `.env.local` and fill in your project values.
# Found in your Supabase dashboard under Project Settings → API.

# Safe to expose to the browser (used by the anon/public client).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Anthropic (Claude) — server-side only, used for quote generation.
# Get a key at https://console.anthropic.com/ → API Keys.
ANTHROPIC_API_KEY=sk-ant-...

# Shared secret guarding POST /api/quote. Callers must send it as the
# `x-api-key` header. Generate one with: openssl rand -hex 32
# The endpoint fails closed (503) if this is unset.
QUOTE_API_SECRET=

# Payments — which provider is active: stripe | square
PAYMENT_PROVIDER=stripe

# Stripe (server-side secrets)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Publishable key is safe for the browser (only needed for client-side Stripe.js).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
